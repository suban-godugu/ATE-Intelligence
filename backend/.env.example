# ══════════════════════════════════════════════════════════════
# ATE Intelligence — Environment Variables Template
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ─── Database ─────────────────────────────────────────────────
# LOCAL (SQLite — for development, no setup needed):
DATABASE_URL="file:./dev.db"

# REMOTE (PostgreSQL — for production):
# DATABASE_URL="postgresql://ate_user:ate_secret@localhost:5432/ate_intelligence"

# ─── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── JWT Auth (used for web UI sessions) ─────────────────────
JWT_ACCESS_SECRET=ate_intelligence_access_secret_change_in_production
JWT_REFRESH_SECRET=ate_intelligence_refresh_secret_change_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI Models — Groq API Key Pool ───────────────────────────
# Each task gets its own key to avoid rate limiting.
# Get your keys at: https://console.groq.com/keys

GROQ_API_KEY_VALIDATOR=your_groq_api_key_here   # File validation AI
GROQ_API_KEY_STIL=your_groq_api_key_here         # STIL file parser
GROQ_API_KEY_LOG=your_groq_api_key_here          # ATE log parser
GROQ_API_KEY_MBIST=your_groq_api_key_here        # MBIST report parser
GROQ_API_KEY_LBIST=your_groq_api_key_here        # LBIST report parser
GROQ_API_KEY_ATPG=your_groq_api_key_here         # ATPG report parser
GROQ_API_KEY_OPTIMIZE=your_groq_api_key_here     # Cost optimization AI
GROQ_API_KEY_ANALYSIS=your_groq_api_key_here     # Pattern analysis + Q&A AI

# Primary fallback (used if a specific key above is not set)
GROQ_API_KEY=your_groq_api_key_here

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── Headless AI API ─────────────────────────────────────────
# Used by external systems (MES, ERP, AI Agents) via x-api-key header.
# Change this to a secure random string in production.
HEADLESS_API_KEY=ate-headless-sk-2024-intelligence-platform
