{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    // "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "rootDir": "..",
    "paths": {
      "@ate/ai-models": ["../ai-models/index.ts"],
      "@ate/ai-models/*": ["../ai-models/*"]
    }
  },
  "include": ["src/**/*", "../ai-models/**/*"],
  "exclude": ["node_modules", "dist"]
}
