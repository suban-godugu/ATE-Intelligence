{
  "name": "ate-intelligence-backend",
  "version": "1.0.0",
  "description": "ATE Intelligence Pattern Analysis Backend API",
  "main": "dist/backend/src/index.js",
  "scripts": {
    "dev": "set NODE_OPTIONS=--max-old-space-size=4096 && ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "cd ../ai-models && npm install --include=dev && npm run build && cd ../backend && npm install --include=dev && tsc",
    "start": "node dist/backend/src/index.js",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.sqlite.prisma",
    "prisma:generate:pg": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=src/prisma/schema.sqlite.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/prisma/schema.sqlite.prisma",
    "prisma:seed": "ts-node src/prisma/seed.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@ate/ai-models": "*",
    "@prisma/client": "^5.14.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "ts-node src/prisma/seed.ts"
  }
}
